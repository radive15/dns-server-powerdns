# Salin file ini menjadi .env lalu isi dengan nilai yang sesuai
# cp .env.example .env

# === PostgreSQL ===
POSTGRES_DB=pdns
POSTGRES_USER=pdns
POSTGRES_PASSWORD=ganti-dengan-password-kuat

# === PowerDNS API ===
# Digunakan untuk autentikasi ke REST API PowerDNS (port 8081)
PDNS_API_KEY=ganti-dengan-api-key-rahasia
